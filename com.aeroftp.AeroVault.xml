<?xml version="1.0" encoding="UTF-8"?>
<mime-info xmlns="http://www.freedesktop.org/standards/shared-mime-info">
  <mime-type type="application/x-aerovault">
    <comment>AeroVault Encrypted Container</comment>
    <comment xml:lang="it">Contenitore cifrato AeroVault</comment>
    <glob pattern="*.aerovault"/>
    <magic priority="60">
      <match type="string" offset="0" value="AEROVAULT2"/>
    </magic>
    <icon name="application-x-aerovault"/>
  </mime-type>
  <mime-type type="application/x-aeroftp">
    <comment>AeroFTP Server Profile Export</comment>
    <comment xml:lang="it">Esportazione profili server AeroFTP</comment>
    <glob pattern="*.aeroftp"/>
    <icon name="application-x-aeroftp"/>
  </mime-type>
  <mime-type type="application/x-aeroftp-keystore">
    <comment>AeroFTP Keystore Bundle (profiles + settings)</comment>
    <comment xml:lang="it">Bundle keystore AeroFTP (profili + impostazioni)</comment>
    <glob pattern="*.aeroftp-keystore"/>
    <icon name="application-x-aeroftp-keystore"/>
  </mime-type>
</mime-info>
