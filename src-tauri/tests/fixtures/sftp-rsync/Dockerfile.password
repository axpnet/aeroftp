# Minimal SSH + rsync fixture for the non-eligible password-auth product-path
# test. This variant deliberately disables pubkey auth so `SftpProvider`
# connects successfully without exposing a delta-eligible session.

FROM alpine:3.19

RUN apk add --no-cache openssh rsync bash \
    && ssh-keygen -A \
    && adduser -D -s /bin/sh testuser \
    && echo "testuser:testpass" | chpasswd \
    && mkdir -p /home/testuser/.ssh /workdir \
    && chown -R testuser:testuser /home/testuser /workdir \
    && chmod 700 /home/testuser/.ssh

RUN sed -i 's/^#\?PasswordAuthentication.*/PasswordAuthentication yes/' /etc/ssh/sshd_config \
    && sed -i 's/^#\?PubkeyAuthentication.*/PubkeyAuthentication no/' /etc/ssh/sshd_config

COPY entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod 755 /usr/local/bin/entrypoint.sh

EXPOSE 22

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]