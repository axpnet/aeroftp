{
    "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
    "productName": "AeroFTP",
    "version": "3.4.4",
    "identifier": "com.aeroftp.AeroFTP",
    "build": {
        "frontendDist": "../dist",
        "devUrl": "http://127.0.0.1:5173",
        "beforeDevCommand": "npm run dev -- --host 127.0.0.1",
        "beforeBuildCommand": "npm run build"
    },
    "app": {
        "windows": [
            {
                "title": "AeroFTP",
                "width": 1540,
                "height": 1050,
                "minWidth": 1024,
                "minHeight": 800,
                "resizable": true,
                "maximizable": true,
                "minimizable": true,
                "closable": true,
                "fullscreen": false,
                "decorations": false,
                "transparent": false,
                "visible": false,
                "dragDropEnabled": false
            }
        ],
        "security": {
            "dangerousDisableAssetCspModification": true,
            "csp": "default-src 'self' asset: http://asset.localhost data: blob:; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval' blob:; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost data: blob: https:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost blob:; worker-src 'self' blob:; media-src 'self' asset: http://asset.localhost data: blob: https:; frame-src 'self' data: blob:; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'",
            "devCsp": "default-src 'self' asset: http://asset.localhost data: blob:; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval' blob:; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost data: blob: https:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost https: wss: http://localhost:* ws://localhost:* http://127.0.0.1:* ws://127.0.0.1:*; worker-src 'self' blob:; media-src 'self' asset: http://asset.localhost data: blob: https:; frame-src 'self' data: blob:; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'",
            "assetProtocol": {
                "enable": true,
                "scope": [
                    "$HOME/**",
                    "$APPDATA/**",
                    "$TEMP/**"
                ]
            }
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "shortDescription": "Modern Multi-Protocol File Client with AI, Encryption & Cloud Storage",
        "longDescription": "AeroFTP is a cross-platform desktop client for FTP, FTPS, SFTP, WebDAV, S3, Google Drive, Dropbox, OneDrive, MEGA, Box, pCloud, Azure Blob, 4shared, Filen, Zoho WorkDrive, Internxt, kDrive, Koofr, FileLu, Yandex Disk, and OpenDrive — 21 protocols, 30+ presets, one app. Features include AeroVault (AES-256-GCM encrypted containers), Cryptomator vault support, AeroAgent AI assistant with 47 tools and 19 providers, Monaco code editor, integrated terminal, dual-pane file browser, AeroCloud personal sync, archive browser (ZIP/7z/TAR/RAR), 47 languages, and dark mode. Built with Rust (Tauri 2) + React 18. Open source under GPL-3.0.",
        "category": "Utility",
        "copyright": "Copyright © 2025-2026 axpdev",
        "license": "GPL-3.0",
        "licenseFile": "../LICENSE",
        "resources": [
            "icons/mimetypes/aerovault.ico"
        ],
        "fileAssociations": [
            {
                "ext": ["aerovault"],
                "contentTypes": ["application/x-aerovault"]
            }
        ],
        "linux": {
            "deb": {
                "depends": [
                    "libgtk-3-0",
                    "libwebkit2gtk-4.1-0",
                    "libayatana-appindicator3-1",
                    "libgstreamer1.0-0",
                    "gstreamer1.0-plugins-base",
                    "gstreamer1.0-plugins-good",
                    "gstreamer1.0-plugins-bad"
                ],
                "files": {
                    "/usr/share/metainfo/com.aeroftp.AeroFTP.metainfo.xml": "../com.aeroftp.AeroFTP.metainfo.xml",
                    "/usr/share/mime/packages/com.aeroftp.AeroVault.xml": "../com.aeroftp.AeroVault.xml",
                    "/usr/share/polkit-1/actions/com.aeroftp.update.policy": "resources/com.aeroftp.update.policy",
                    "/usr/lib/aeroftp/aeroftp-update-helper": "resources/aeroftp-update-helper",
                    "/usr/lib/aeroftp/aeroftp-restart-helper": "resources/aeroftp-restart-helper",
                    "/usr/share/icons/hicolor/16x16/mimetypes/application-x-aerovault.png": "icons/mimetypes/application-x-aerovault-16.png",
                    "/usr/share/icons/hicolor/24x24/mimetypes/application-x-aerovault.png": "icons/mimetypes/application-x-aerovault-24.png",
                    "/usr/share/icons/hicolor/32x32/mimetypes/application-x-aerovault.png": "icons/mimetypes/application-x-aerovault-32.png",
                    "/usr/share/icons/hicolor/48x48/mimetypes/application-x-aerovault.png": "icons/mimetypes/application-x-aerovault-48.png",
                    "/usr/share/icons/hicolor/64x64/mimetypes/application-x-aerovault.png": "icons/mimetypes/application-x-aerovault-64.png",
                    "/usr/share/icons/hicolor/128x128/mimetypes/application-x-aerovault.png": "icons/mimetypes/application-x-aerovault-128.png",
                    "/usr/share/icons/hicolor/256x256/mimetypes/application-x-aerovault.png": "icons/mimetypes/application-x-aerovault-256.png",
                    "/usr/share/icons/hicolor/512x512/mimetypes/application-x-aerovault.png": "icons/mimetypes/application-x-aerovault-512.png",
                    "/usr/share/icons/hicolor/scalable/mimetypes/application-x-aerovault.svg": "icons/mimetypes/application-x-aerovault.svg"
                },
                "postInstallScript": "scripts/deb-postinst.sh"
            }
        },
        "macOS": {
            "minimumSystemVersion": "10.13",
            "entitlements": "entitlements.plist"
        },
        "windows": {
            "wix": {
                "bannerPath": "installer/banner.bmp",
                "dialogImagePath": "installer/dialog.bmp"
            },
            "nsis": {
                "installerIcon": "icons/icon.ico",
                "headerImage": "installer/header.bmp",
                "sidebarImage": "installer/sidebar.bmp",
                "installerHooks": "installer/hooks.nsh"
            }
        }
    },
    "plugins": {}
}