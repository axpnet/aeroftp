#!/bin/bash
# AeroFTP Update Helper
# Executed via pkexec with Polkit policy com.aeroftp.update.install
# Installs .deb or .rpm packages with proper authentication dialog.

set -euo pipefail

if [ $# -ne 2 ]; then
    echo "Usage: aeroftp-update-helper <package-file> <expected-sha256>" >&2
    exit 1
fi

FILE="$1"
EXPECTED_SHA256="$2"

if [ ! -f "$FILE" ]; then
    echo "Error: File not found: $FILE" >&2
    exit 1
fi

case "$EXPECTED_SHA256" in
    [0-9a-fA-F][0-9a-fA-F]*)
        ;;
    *)
        echo "Error: Invalid expected SHA-256" >&2
        exit 1
        ;;
esac

if [ ${#EXPECTED_SHA256} -ne 64 ]; then
    echo "Error: Invalid expected SHA-256 length" >&2
    exit 1
fi

# Only allow files from user home or temp directories
# Note: Downloads folder name varies by locale (Downloads, Scaricati, Téléchargements, etc.)
case "$FILE" in
    /home/*/*|/tmp/*|/var/tmp/*)
        ;;
    *)
        echo "Error: Package must be in a user home or temp directory" >&2
        exit 1
        ;;
esac

ACTUAL_SHA256="$(sha256sum "$FILE" | awk '{print $1}')"
if [ "$ACTUAL_SHA256" != "$EXPECTED_SHA256" ]; then
    echo "Error: Package hash mismatch" >&2
    exit 1
fi

TMP_COPY="$(mktemp /var/tmp/aeroftp-update-XXXXXX.pkg)"
trap 'rm -f "$TMP_COPY"' EXIT
cp --preserve=mode "$FILE" "$TMP_COPY"

COPIED_SHA256="$(sha256sum "$TMP_COPY" | awk '{print $1}')"
if [ "$COPIED_SHA256" != "$EXPECTED_SHA256" ]; then
    echo "Error: Package copy hash mismatch" >&2
    exit 1
fi

case "$FILE" in
    *.deb)
        exec dpkg -i "$TMP_COPY"
        ;;
    *.rpm)
        exec rpm -U "$TMP_COPY"
        ;;
    *)
        echo "Error: Unsupported package format (only .deb and .rpm)" >&2
        exit 1
        ;;
esac
