<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!--
    AeroFTP entitlements for direct distribution (GitHub Releases, website).
    App Sandbox is NOT enabled here — it is only required for Mac App Store.
    Without a valid Apple Developer signature, App Sandbox blocks WebKit
    from loading the frontend, causing a frozen/unresponsive UI.
    See: https://github.com/axpdev-lab/aeroftp/issues/62
  -->

  <!-- Hardened Runtime: Allow JIT compilation (required for WebKit/JavaScriptCore) -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>

  <!-- Hardened Runtime: Allow unsigned executable memory (required for WebKit JIT on some macOS versions) -->
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>

  <!-- Hardened Runtime: Deny DYLD environment variables (security hardening) -->
  <key>com.apple.security.cs.allow-dyld-environment-variables</key>
  <false/>

  <!-- Hardened Runtime: Disable library validation (required for WebKit dylibs) -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>

  <!-- Network Client Permission — Required for FTP/SFTP/WebDAV/cloud connections -->
  <key>com.apple.security.network.client</key>
  <true/>

  <!-- Network Server Permission — Required for OAuth2 callback listener and FTP PASV -->
  <key>com.apple.security.network.server</key>
  <true/>
</dict>
</plist>
